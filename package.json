		"@types/node": "^26",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.11.14",
		"@types/react": "^19.2.17",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "1.0.0-beta.22",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"shadcn": "^4.11.0",
		"typescript": "^6.0.3"
