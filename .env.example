# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/authorization

# Redis
CACHE_URL=redis://localhost:6379
CACHE_KEY_PREFIX=authorization

# Email
# Set EMAIL_PREVIEW=true when running `pnpm email:dev`.
EMAIL_PREVIEW=false
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
EMAIL_TWO_FACTOR_URL_BASE=http://localhost:3000/verify-sign-in
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=ARSN
SMTP_FROM_ADDRESS=noreply@arsn.cc

# Registration
# Set to "true" to disable new user registration
DISABLE_REGISTRATION=false

# Primary color (hex format — e.g. "#22c55e" for green)
# Used by both the web UI and email templates
PRIMARY_COLOR=#22c55e

# S3-compatible storage
STORAGE_BUCKET=uploads
STORAGE_REGION=auto
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000/uploads
